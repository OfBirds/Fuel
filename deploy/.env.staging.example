# Copy to .env.staging on the host and fill in real secrets. Do NOT commit the
# real file.
COMPOSE_PROJECT_NAME=fuel-staging

# Image built from `main` and pushed to GHCR by CI.
APP_IMAGE=ghcr.io/trifunovich/fuel:staging

# App (SPA + API) reachable on the LAN at this port.
APP_PORT=9223

# Postgres published on the LAN for DBeaver.
DB_HOST_PORT=5435

# Seq log UI on the LAN.
SEQ_PORT=9233

DB_NAME=fuel
DB_USER=fuel
DB_PASSWORD=change-me-staging

# Release notifications. Staging never emails, so the flag is false and SMTP can
# stay blank here.
NOTIFY_ON_DEPLOY=false
PUBLIC_BASE_URL=http://vm.example.lan:9223
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_FROM=
SMTP_PASS=
SMTP_ACCEPT_ALL_CERTS=true

# Periodic on-disk backups (BackupService). Off on staging.
BACKUP_ENABLED=false
BACKUP_INTERVAL=weekly

# AI nutrition estimator (text/photo). Provider is an operator choice, picked here.
# AI_API_KEY is a SECRET — set it only in the real /opt/fuel/.env.staging, never commit.
# Leave AI_ENABLED=false to run manual-only.
AI_ENABLED=false
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
AI_API_KEY=
AI_TIMEOUT_SECONDS=30
