# Copy to .env.staging on the host and fill in real secrets. Do NOT commit the
# real file.
COMPOSE_PROJECT_NAME=fuel-staging

# Image built from `main` and pushed to GHCR by CI.
APP_IMAGE=ghcr.io/trifunovich/fuel:staging

# App (SPA + API) reachable on the LAN at this port.
APP_PORT=9223

# Postgres published on the LAN for DBeaver.
DB_HOST_PORT=5435

# Seq log UI on the LAN.
SEQ_PORT=9233

DB_NAME=fuel
DB_USER=fuel
DB_PASSWORD=change-me-staging

# Release notifications. Staging never emails, so the flag is false and SMTP can
# stay blank here.
NOTIFY_ON_DEPLOY=false
PUBLIC_BASE_URL=http://vm.example.lan:9223
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_FROM=
SMTP_PASS=
SMTP_ACCEPT_ALL_CERTS=true

# Periodic on-disk backups (BackupService). Off on staging.
BACKUP_ENABLED=false
BACKUP_INTERVAL=weekly

# AI nutrition estimator (text/photo) — see docs/ai-providers.md.
# The provider LIST is a separate hot-reloadable JSON file; here we only set its path and
# the secret key VALUES. A provider in the JSON references a key by name (keyRef "claude"
# → AI_KEY_CLAUDE). Local/key-less providers (Ollama) need no key here. Empty AI_KEY_* +
# an empty/absent providers file = AI simply off (the UI shows "not configured").
#
# AI_CONFIG_HOST_PATH: host path to the providers JSON, bind-mounted into the app.
AI_CONFIG_HOST_PATH=/opt/fuel/ai-providers.staging.json
AI_TIMEOUT_SECONDS=30
# Secret key VALUES (referenced by keyRef in the JSON). Set in the real /opt/fuel/.env.staging.
AI_KEY_DEEPSEEK=
AI_KEY_CLAUDE=
