# Copy to .env.prod on the host and fill in real secrets. Do NOT commit the
# real file.
COMPOSE_PROJECT_NAME=fuel-prod

# Image built from `release` and pushed to GHCR by CI.
APP_IMAGE=ghcr.io/trifunovich/fuel:prod

# App (SPA + API) reachable on the LAN at this port.
APP_PORT=9224

# Postgres published on the LAN for DBeaver.
DB_HOST_PORT=5436

# Seq log UI on the LAN.
SEQ_PORT=9234

DB_NAME=fuel
DB_USER=fuel
DB_PASSWORD=change-me-prod

# Auth token signing. REQUIRED: a random secret of at least 32 chars (e.g.
# `openssl rand -base64 48`). If left blank the app generates an ephemeral key and
# logs every user out on each restart. JWT_EXPIRY_DAYS controls how long a login lasts.
JWT_SIGNING_KEY=change-me-prod-at-least-32-chars-long
JWT_EXPIRY_DAYS=30

# Release notifications. Prod emails opted-in users on each new version.
# Sender = Gmail SMTP with an app password (requires 2-Step Verification on the
# account). Port 587 -> STARTTLS in the app. SMTP_PASS is the 16-char app
# password, set only in .env.prod on the server — never commit it.
NOTIFY_ON_DEPLOY=true
PUBLIC_BASE_URL=https://app.example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@gmail.com
SMTP_FROM=your-account@gmail.com
SMTP_PASS=app-password-16-chars
SMTP_ACCEPT_ALL_CERTS=false

# Periodic on-disk backups (BackupService). Enable + pick a cadence.
BACKUP_ENABLED=true
BACKUP_INTERVAL=weekly

# AI nutrition estimator (text/photo) — see docs/ai-providers.md.
# The provider LIST is a separate hot-reloadable JSON file; here we only set its path and
# the secret key VALUES. A provider in the JSON references a key by name (keyRef "claude"
# → AI_KEY_CLAUDE). Adding a new key = add a line here + redeploy.
AI_CONFIG_HOST_PATH=/opt/fuel/ai-providers.prod.json
AI_TIMEOUT_SECONDS=30
AI_KEY_DEEPSEEK=your-deepseek-api-key
AI_KEY_CLAUDE=your-anthropic-api-key

# Barcode / EAN product lookup (docs/barcode-lookup.md). Open Food Facts — free, no key.
# BARCODE_ENABLED=true shows the scan affordance on the entry screen.
BARCODE_ENABLED=false
BARCODE_BASE_URL=https://world.openfoodfacts.org
BARCODE_TIMEOUT_SECONDS=10
